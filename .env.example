# Ollama configuration
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_AUTO_START=true

# OpenRouter configuration
OPENROUTER_ENABLED=false
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default provider on startup (ollama or openrouter)
AI_PROVIDER=ollama

# Custom models (JSON array)
OLLAMA_MODELS=[
            {"id":"llama3.2","name":"Llama 3.2","vision":false},
            {"id":"llama3.2-vision","name":"Llama 3.2 Vision","vision":true}
]

OPENROUTER_MODELS=[
    {"id":"nvidia/nemotron-3-super-120b-a12b:free","name":"Nemotron 3 Super (free)","vision":false},
    {"id":"nvidia/nemotron-3-nano-30b-a3b:free","name":"Nemotron 3 Nano (free)","vision":true}
]